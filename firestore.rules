rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Règle par défaut : tout est interdit
    match /{document=**} {
      allow read, write: if false;
    }

    // ============================================
    // TÂCHES PRIVÉES
    // ============================================
    // Seul le propriétaire peut lire/écrire ses tâches privées
    match /users/{userId}/tasks/{taskId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================
    // PROFIL UTILISATEUR
    // ============================================
    // Lecture : tout utilisateur connecté peut lire (pour trouver par email)
    // Écriture : seul le propriétaire peut modifier son profil
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================
    // LISTES PARTAGÉES
    // ============================================
    match /sharedLists/{listId} {
      // Lecture : seuls les membres de la liste peuvent lire
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      
      // Création : le créateur doit être le owner et doit être dans les membres
      allow create: if request.auth != null 
        && request.auth.uid == request.resource.data.ownerId 
        && request.auth.uid in request.resource.data.members;
      
      // Mise à jour : seul le owner peut modifier (ajouter/retirer des membres)
      allow update: if request.auth != null && request.auth.uid == resource.data.ownerId;
      
      // Suppression : seul le owner peut supprimer
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;

      // ============================================
      // TÂCHES D'UNE LISTE PARTAGÉE
      // ============================================
      // Les membres de la liste partagée peuvent lire et modifier les tâches
      match /tasks/{taskId} {
        allow read, write: if request.auth != null 
          && request.auth.uid in get(/databases/$(database)/documents/sharedLists/$(listId)).data.members;
      }
    }
  }
}
